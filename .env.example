# Copy to .env and fill in. The app runs with everything below blank/default,
# except Google sign-in (needs the GOOGLE_* vars) and real email (needs SMTP_*).

PORT=3000
# Public base URL used to build verification links and the Google OAuth callback.
APP_BASE_URL=http://localhost:3000

# Secret used to sign the session cookie. Use a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth 2.0 credentials (https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI must be: <APP_BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP for verification emails. Leave blank in dev to log the link to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Vehic-le <no-reply@example.com>"
